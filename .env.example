# ─────────────────────────────────────────────────────────
# Environment Variables — copy to .env.local and fill in
# ─────────────────────────────────────────────────────────

# GCP / Firebase
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
FIREBASE_PROJECT_ID=your-firebase-project-id
BIGQUERY_PROJECT_ID=your-gcp-project-id

# Storage
GCS_BUCKET=your-gcs-bucket
GCS_BASE_URL=https://storage.googleapis.com/your-gcs-bucket
GCS_CDN_BUCKET=your-cdn-bucket
CDN_BASE_URL=https://your-cdn-domain.com

# API Keys
GEMINI_API_KEY=your-gemini-api-key
GOOGLE_MAPS_API_KEY=your-maps-api-key
BLS_API_KEY=your-bls-api-key
FRED_API_KEY=your-fred-api-key
RESEND_API_KEY=your-resend-api-key

# Auth
FORGE_API_SECRET=your-hmac-secret
FORGE_V1_API_KEY=your-v1-api-key
CRON_SECRET=your-cron-secret
ADMIN_EMAIL_ALLOWLIST=admin@example.com

# Firebase (frontend)
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_API_KEY=your-firebase-api-key

# Services
CRAWL4AI_URL=http://localhost:11235
