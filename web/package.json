{
  "name": "hephae-forge",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"next dev\" \"uvicorn backend.main:app --host 0.0.0.0 --port 8000 --reload\"",
    "dev:next": "next dev",
    "dev:api": "uvicorn backend.main:app --host 0.0.0.0 --port 8000 --reload",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:py": "pytest backend/tests/",
    "test:integration": "./scripts/test-integration.sh",
    "test:integration:fast": "./scripts/test-integration.sh --level 1 --level 2",
    "test:integration:report": "./scripts/test-integration.sh --report",
    "test:cloud": "./scripts/trigger-cloud-tests.sh",
    "test:cloud:status": "./scripts/trigger-cloud-tests.sh --status"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.3",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.1.2",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
